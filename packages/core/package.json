{
  "name": "@stage-cut/core",
  "version": "0.5.0-beta.2",
  "description": "Serializable project model and compiled timeline for Stagecut DOM animations.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugozhou-ai/stage-cut.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/hugozhou-ai/stage-cut/issues"
  },
  "homepage": "https://github.com/hugozhou-ai/stage-cut#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build && node ../../scripts/create-cjs-types.mjs dist/types",
    "prepack": "pnpm run build",
    "test": "pnpm exec vitest run src/core.test.ts",
    "test:coverage": "pnpm exec vitest run src/core.test.ts --coverage --coverage.thresholds.lines=95 --coverage.thresholds.functions=95 --coverage.thresholds.statements=95 --coverage.thresholds.branches=95",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
