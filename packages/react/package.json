{
  "name": "@stagecut/react",
  "version": "0.5.0-beta.2",
  "description": "React and Remotion-powered Web DOM animation player for Stagecut.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hugozhou-ai/stage-cut.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/hugozhou-ai/stage-cut/issues"
  },
  "homepage": "https://github.com/hugozhou-ai/stage-cut#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && vite build && node ../../scripts/create-cjs-types.mjs dist/types",
    "test": "pnpm exec vitest run src/react.test.tsx --environment jsdom",
    "test:coverage": "pnpm exec vitest run src/react.test.tsx --environment jsdom --coverage --coverage.thresholds.lines=90 --coverage.thresholds.functions=90 --coverage.thresholds.statements=90 --coverage.thresholds.branches=90",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/player": "4.0.482",
    "@stagecut/core": "workspace:^",
    "remotion": "4.0.482"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  }
}
